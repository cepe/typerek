{
  "name": "typerek",
  "private": true,
  "description": "Frontend toolchain (Tailwind CSS). Portable to a future React + Vite frontend.",
  "scripts": {
    "build:css": "tailwindcss -i ./app/frontend/styles/application.tailwind.css -o ./app/assets/stylesheets/application.css --minify",
    "watch:css": "tailwindcss -i ./app/frontend/styles/application.tailwind.css -o ./app/assets/stylesheets/application.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}