# Runtime environment for the beta instance (docker-compose.beta.yaml → web-beta).
# Copy to .env.beta on the beta host and fill in real values.
#
# The beta service joins the existing `typerek_default` network and reuses the
# production Postgres, so point it at a SEPARATE database to keep beta and prod
# data apart.

# Beta runs the production build (assets are baked into the image).
export RAILS_ENV=production

# Generate a unique secret with: ./run rails secret
export SECRET_KEY_BASE=replace_me

# Seed credentials for the initial admin account (db/seeds.rb needs both).
export TYPEREK_ADMIN_USERNAME=admin
export TYPEREK_ADMIN_PASSWORD=change_me

# Invite link to the community Discord server. Served to signed-in members only
# (via GET /api/v1/me) and shown as a button on the info page. Leave it unset to
# hide the button entirely.
#export TYPEREK_DISCORD_URL=https://discord.gg/your-invite

# Puma bind port inside the container (the beta compose publishes it as 8001 on
# the host).
export PORT=8000
export WEB_CONCURRENCY=1
export RAILS_MAX_THREADS=1

# Database: the shared Postgres reachable as `postgres` over typerek_default,
# with a dedicated database so beta never touches production data.
export POSTGRES_USER=postgres
export POSTGRES_PASSWORD=password
export POSTGRES_HOST=postgres
export POSTGRES_DB=typerek_beta

# Serve the built SPA and static assets from Rails (nginx fronts it on the host).
export RAILS_SERVE_STATIC_FILES=true
export RAILS_LOG_TO_STDOUT=true