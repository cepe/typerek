# Env for the standalone Java stack (docker-compose.java.yaml). Copy to .env.java.
#
#   cp .env.java.example .env.java
#   docker compose -f docker-compose.java.yaml --env-file .env.java up --build -d

# JWT (HS256) secret. For a pure smoke test any value works; to verify that tokens
# stay valid across the cutover, use the SAME value as production. Use >= 32 chars.
SECRET_KEY_BASE=java-smoke-secret-change-me-0123456789-abcd

# Dedicated database for this stack — never the production one.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=typerek_java
POSTGRES_HOST=postgres-java
POSTGRES_PORT=5432

# Bind port inside the container (the compose publishes it as 8002 on the host).
PORT=8000

# Seed an admin + sample matches on first boot (only when the DB is empty).
APP_SEED=true
TYPEREK_ADMIN_USERNAME=admin
TYPEREK_ADMIN_PASSWORD=password1!

# Optional: community Discord link shown to signed-in users.
#TYPEREK_DISCORD_URL=https://discord.gg/your-invite
