# Base URL of the Typerek API. Defaults to the relative "/api/v1", which works
# both in dev (Vite proxies /api to the Rails backend on :8000) and in production
# when the SPA is served from the same origin as the API. Override only when the
# API lives on a different origin (then the backend must enable CORS).
# VITE_API_BASE_URL=https://api.example.com/api/v1
