<%= render partial: 'shared/menu', locals: { s: 'users' } %>
<% content_for :title, "Typy: #{@user.username}" %>

<div class='mb-5'>
  <h1 class='flex items-center gap-2'><i class='fa fa-user text-brand'></i> Typy użytkownika <%= @user.username %></h1>
  <p class='mt-1 text-muted'>Liczba trafień: <span class='font-semibold text-ink'><%= @user.accuracy %></span></p>
</div>

<% if @matches_started.empty? %>
  <div class='card card-body text-center text-muted'>Brak rozegranych meczów</div>
<% else %>
  <div class='space-y-4'>
    <% @matches_started.group_by(&:start_date).each do |start_date, games| %>
      <section class='card overflow-hidden'>
        <div class='card-header'>
          <h3 class='text-sm font-bold uppercase tracking-wide text-muted'>
            <%= l(start_date, format: :only_date) %>
          </h3>
        </div>
        <div class='divide-y divide-line/60'>
          <% games.each do |match| %>
            <div class='flex flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:gap-4 sm:px-5'>
              <%= render 'matches/match_line', match: match %>
              <div class='sm:w-[340px]'>
                <%= render partial: 'matches/buttons', locals: { match: match, answer: (match.answers & @answers).first } %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
<% end %>
