<%= render partial: 'shared/menu', locals: { s: 'users' } %>
<% content_for :title, 'Zaproszenia' %>

<h1 class='mb-4 flex items-center gap-2'><i class='fa fa-envelope-o text-brand'></i> Zaproszenia</h1>

<section class='card card-body mb-8'>
  <%= form_for @user, url: users_path, html: { method: :post } do |f| %>
    <div class='flex flex-col gap-3 sm:flex-row sm:items-end'>
      <div class='flex-1'>
        <%= f.label :username, 'Login', class: 'label' %>
        <%= f.text_field :username, class: 'field', autocapitalize: 'none' %>
      </div>
      <%= f.submit 'Generuj zaproszenie', class: 'btn btn-brand' %>
    </div>
  <% end %>
</section>

<% users = User.includes(:invited_by).order(:username).to_a %>
<h2 class='mb-4 flex items-center gap-2'>
  <i class='fa fa-users text-brand'></i> Lista użytkowników
  <span class='badge-count'><%= users.size %></span>
</h2>

<section class='card overflow-hidden' id='list-of-users'>
  <div class='user-head'>
    <span>Użytkownik</span>
    <span>Stan konta</span>
    <span>Potwierdzenie</span>
    <span class='justify-self-end'>Akcje</span>
  </div>

  <div class='divide-y divide-line/60'>
    <% users.each do |user| %>
      <div class='user-row'>
        <div class='ur-user'>
          <%= link_to user.username, user_path(user), class: 'block truncate font-semibold text-ink hover:text-brand' %>
          <% if user.invited_by_username.present? %>
            <div class='truncate text-xs text-muted'>zaproszony przez <%= user.invited_by_username %></div>
          <% end %>
        </div>

        <div class='ur-status'><%= user_status(user) %></div>

        <div class='ur-pay'>
          <%= turbo_frame_tag user do %>
            <%= link_to fin_user_path(user), title: 'Kliknij, aby przełączyć', data: { turbo: true, turbo_method: :post } do %>
              <%= user_fin(user) %>
            <% end %>
          <% end %>
        </div>

        <div class='ur-actions'>
          <% if user != Current.user %>
            <%= link_to resend_invitation_user_path(user), class: 'btn-action',
                        data: { confirm: 'Czy na pewno chcesz wygenerować ponownie link z zaproszeniem?' } do %>
              <i class='fa fa-refresh'></i> Nowy link
            <% end %>
            <%= link_to user_path(user), class: 'btn-action btn-action-danger', method: :delete,
                        data: { confirm: 'Czy na pewno chcesz usunąć użytkownika?' } do %>
              <i class='fa fa-trash'></i> Usuń
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
