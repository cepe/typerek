<%= render partial: 'shared/menu', locals: { s: 'ranking' } %>

<h1 class='mb-4 flex items-center gap-2'><i class='fa fa-trophy text-brand'></i> Ranking</h1>

<div class='mx-auto max-w-xl'>
  <ul class='card divide-y divide-line/60 overflow-hidden'>
    <% @users.each do |user| %>
      <% position = @points.index(user.points) + 1 %>
      <% me = Current.user == user %>
      <% badge = { 1 => 'bg-yellow-400 text-white', 2 => 'bg-gray-300 text-ink', 3 => 'bg-amber-600 text-white' }[position] || 'bg-surface text-muted' %>
      <li class="flex items-center gap-3 px-4 py-3 <%= 'bg-brand-tint' if me %>">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm font-bold tabular-nums <%= badge %>">
          <%= position %>
        </span>
        <span class='flex-1 truncate font-medium'>
          <%= link_to user.username, user_path(user), class: 'text-ink hover:text-brand' %>
          <% if me %><span class='ml-1 text-xs font-normal text-brand'>(Ty)</span><% end %>
        </span>
        <span class='text-right leading-tight'>
          <span class='font-bold text-ink tabular-nums'><%= number_with_precision(user.points) %></span>
          <span class='block text-xs text-muted'><%= user.accuracy %> trafień</span>
        </span>
      </li>
    <% end %>
  </ul>
</div>
