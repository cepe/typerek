<%= render partial: 'shared/menu', locals: { s: 'matches' } %>
<% content_for :title, "#{@match.team_a} – #{@match.team_b}" %>

<div class='mx-auto max-w-3xl space-y-6'>
  <%= link_to matches_path, class: 'inline-flex items-center gap-1 text-sm text-muted hover:text-brand' do %>
    <i class='fa fa-angle-left'></i> Mecze
  <% end %>

  <!-- Match header -->
  <section class='card card-body'>
    <% if can? :update, @match %>
      <div class='mb-3 flex justify-end'>
        <%= link_to edit_match_path(@match), class: 'btn btn-outline btn-sm' do %>
          <i class='fa fa-pencil'></i> Edytuj
        <% end %>
      </div>
    <% end %>

    <% flag_before = 'mr-4 inline-block h-5 w-7 rounded-sm align-[-0.2em]' %>
    <% flag_after = 'ml-4 inline-block h-5 w-7 rounded-sm align-[-0.2em]' %>
    <div class='flex items-center justify-center gap-2 sm:gap-3'>
      <div class='flex-1 text-right text-lg font-bold text-ink'><%= @match.team_a %><%= flag_icon(@match.team_a, classes: flag_after) %></div>
      <div class='shrink-0 rounded-lg bg-surface px-4 py-2 text-2xl font-bold tabular-nums text-ink'>
        <%= formatted_score(@match) %>
      </div>
      <div class='flex-1 text-left text-lg font-bold text-ink'><%= flag_icon(@match.team_b, classes: flag_before) %><%= @match.team_b %></div>
    </div>
    <p class='mt-3 text-center text-sm text-muted'>
      <i class='fa fa-clock-o'></i> <%= l(@match.start, format: :short) %>
    </p>
  </section>

  <!-- Your bet -->
  <section class='card'>
    <div class='card-header'>
      <h3 class='flex items-center gap-2'><i class='fa fa-user text-brand'></i> Twój typ</h3>
    </div>
    <div id='my-bet' class='card-body'>
      <% unless @match.started? %>
        <p class='mb-3 text-sm text-muted'>Wybierz swój typ, klikając w kurs:</p>
      <% end %>
      <%= render partial: 'buttons', locals: { match: @match, answer: @answer } %>
    </div>
  </section>

  <!-- Other participants -->
  <% if @match.started? %>
    <section id='others-bets' class='card overflow-hidden'>
      <div class='card-header'>
        <h3 class='flex items-center gap-2'><i class='fa fa-users text-brand'></i> Typy uczestników</h3>
      </div>
      <div class='divide-y divide-line/60'>
        <% @users.each do |user| %>
          <% answer = @answers[user.id] %>
          <div class='flex flex-col gap-2 px-4 py-3 sm:flex-row sm:items-center sm:gap-4 sm:px-5'>
            <div class='font-medium'>
              <%= link_to user.username, user_path(user), class: 'text-ink hover:text-brand' %>
            </div>
            <% if answer.blank? %>
              <span class='text-sm text-muted sm:ml-auto'>brak typu</span>
            <% else %>
              <div class='bet-grid sm:ml-auto sm:w-[340px]'>
                <% MatchesHelper::BET_TYPES.each do |result, label| %>
                  <% chosen = answer.result == result %>
                  <div class="bet <%= chosen ? 'bet-active' : 'border-line bg-surface/60 text-muted' %>">
                    <span class='bet-key'><%= label %></span>
                    <span class='bet-odds'><%= formatted_odds(@match.public_send(result)) %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>
</div>
