<%= form_for @match do |f| %>
  <div class='space-y-5'>
    <div class='grid grid-cols-1 gap-4 sm:grid-cols-2'>
      <div>
        <%= f.label :team_a, 'Drużyna 1', class: 'label' %>
        <%= f.text_field :team_a, class: 'field', autocapitalize: 'none' %>
      </div>
      <div>
        <%= f.label :team_b, 'Drużyna 2', class: 'label' %>
        <%= f.text_field :team_b, class: 'field', autocapitalize: 'none' %>
      </div>
    </div>

    <div>
      <span class='label'>Kursy</span>
      <div class='grid grid-cols-3 gap-3 sm:grid-cols-6'>
        <% { win_a: '1', tie: 'X', win_b: '2', win_tie_a: '1X', win_tie_b: 'X2', not_tie: '12' }.each do |attr, lbl| %>
          <div>
            <%= f.label attr, lbl, class: 'mb-1 block text-center text-xs font-bold text-muted' %>
            <%= f.number_field attr, step: 0.01, min: 0, class: 'field text-center', disabled: @match.started? && @match.persisted? %>
          </div>
        <% end %>
      </div>
    </div>

    <div>
      <%= f.label :start, 'Data rozpoczęcia', class: 'label' %>
      <%= f.datetime_select :start, {}, class: 'field mr-1 inline-block w-auto', disabled: @match.started? && @match.persisted? %>
    </div>

    <hr class='border-line'>

    <div>
      <span class='label'>Wynik</span>
      <div class='grid grid-cols-2 gap-3 sm:max-w-xs'>
        <div>
          <%= f.label :result_a, 'Drużyna 1', class: 'mb-1 block text-center text-xs font-bold text-muted' %>
          <%= f.number_field :result_a, step: 1, min: 0, class: 'field text-center', disabled: !@match.started? && @match.persisted? %>
        </div>
        <div>
          <%= f.label :result_b, 'Drużyna 2', class: 'mb-1 block text-center text-xs font-bold text-muted' %>
          <%= f.number_field :result_b, step: 1, min: 0, class: 'field text-center', disabled: !@match.started? && @match.persisted? %>
        </div>
      </div>
    </div>

    <div class='flex justify-end gap-2'>
      <%= link_to 'Anuluj', matches_path, class: 'btn btn-ghost' %>
      <%= f.submit 'Zapisz', class: 'btn btn-brand', data: { disable_with: 'Zapisuję…' } %>
    </div>
  </div>
<% end %>
