<% if matches.empty? %>
  <div class='card card-body text-center text-muted'>Brak meczów</div>
<% else %>
  <div class='space-y-4'>
    <% matches.group_by(&:start_date).each do |start_date, games| %>
      <section class='card overflow-hidden'>
        <div class='card-header'>
          <h3 class='text-sm font-bold uppercase tracking-wide text-muted'>
            <%= l(start_date, format: :only_date) %>
          </h3>
        </div>
        <div class='divide-y divide-line/60'>
          <% games.each do |match| %>
            <div class='flex flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:gap-4 sm:px-5'>
              <%= link_to match_path(match), class: 'group flex items-center gap-3' do %>
                <span class='w-11 shrink-0 text-sm font-semibold tabular-nums text-muted'>
                  <%= l(match.start, format: :only_time) %>
                </span>
                <span class='inline-flex shrink-0 items-center rounded-md bg-surface px-2 py-1 text-sm font-bold tabular-nums text-ink'>
                  <%= formatted_score(match) %>
                </span>
                <span class='font-semibold text-ink group-hover:text-brand'>
                  <%= flag_icon(match.team_a) %><%= match.team_a %>
                  <span class='text-muted'>–</span>
                  <%= flag_icon(match.team_b) %><%= match.team_b %>
                </span>
              <% end %>
              <div class='sm:ml-auto sm:w-[340px]'>
                <%= render partial: 'buttons', locals: { match: match, answer: (match.answers & @answers).first } %>
              </div>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
<% end %>
