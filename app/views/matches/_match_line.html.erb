<%# Clickable match line: time on the left, then "TeamA <flag>  score  <flag> TeamB"
    with the score centered between the teams and the flags on the inner side. %>
<%= link_to match_path(match), class: 'group flex items-center gap-2 sm:flex-1 sm:gap-3' do %>
  <span class='w-11 shrink-0 text-sm font-semibold tabular-nums text-muted'>
    <%= l(match.start, format: :only_time) %>
  </span>
  <span class='flex flex-1 items-center justify-center gap-2 sm:gap-3'>
    <span class='flex-1 text-right font-semibold text-ink group-hover:text-brand'>
      <%= match.team_a %><%= flag_icon(match.team_a, classes: 'ml-2 inline-block h-3.5 w-5 rounded-sm align-[-0.15em]') %>
    </span>
    <span class='shrink-0 rounded-md bg-surface px-2 py-1 text-sm font-bold tabular-nums text-ink'>
      <%= formatted_score(match) %>
    </span>
    <span class='flex-1 text-left font-semibold text-ink group-hover:text-brand'>
      <%= flag_icon(match.team_b, classes: 'mr-2 inline-block h-3.5 w-5 rounded-sm align-[-0.15em]') %><%= match.team_b %>
    </span>
  </span>
<% end %>
