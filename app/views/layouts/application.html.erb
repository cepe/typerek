<!DOCTYPE html>
<html lang='pl'>
<head>
  <title><%= content_for?(:title) ? "#{yield(:title)} · Typerek" : 'Typerek' %></title>
  <meta http-equiv='X-UA-Compatible' content='IE=edge'>
  <meta name='viewport' content='width=device-width, initial-scale=1'>
  <link rel='icon' href='/icon.svg' type='image/svg+xml'>
  <link rel='preconnect' href='https://fonts.googleapis.com'>
  <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin>
  <link href='https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap' rel='stylesheet'>
  <%= stylesheet_link_tag 'application', media: 'all' %>
  <%= stylesheet_link_tag 'icons', media: 'all' %>
  <%= javascript_importmap_tags %>
  <%= csrf_meta_tags %>
</head>
<body class='flex min-h-screen flex-col'>
<header class='bg-brand text-white shadow-sm'>
  <nav class='container-app flex flex-wrap items-center justify-between gap-x-8 gap-y-2 py-3'>
    <div class='flex w-full items-center justify-between lg:w-auto'>
      <%= link_to root_path, class: 'flex items-center gap-2 text-lg font-bold text-white hover:text-white' do %>
        <i class='fa fa-futbol-o'></i>
        Typerek <span class='font-normal opacity-80'>2026</span>
      <% end %>
      <% if Current.user.present? %>
        <button data-nav-toggle type='button' class='rounded-md p-2 hover:bg-white/10 lg:hidden' aria-label='Menu'>
          <i class='fa fa-bars text-xl'></i>
        </button>
      <% end %>
    </div>
    <%= yield :menu %>
  </nav>
</header>

<main class='container-app flex-1 py-6'>
  <% if !notice.blank? || !alert.blank? %>
    <div data-alert data-alert-auto role='alert'
         class='mb-4 flex items-start justify-between gap-3 rounded-lg px-4 py-3 text-sm <%= notice.present? ? 'bg-brand-tint text-brand-dark' : 'bg-danger-tint text-danger' %>'>
      <span><%= notice || alert %></span>
      <button data-alert-close type='button' class='shrink-0 opacity-70 hover:opacity-100' aria-label='Zamknij'>
        <i class='fa fa-times'></i>
      </button>
    </div>
  <% end %>

  <%= yield %>
</main>

<footer class='border-t border-line/70 py-4 text-center text-xs text-muted'>
  Typerek &middot; Mistrzostwa Świata 2026
</footer>
</body>
</html>
