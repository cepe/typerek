# Env for running the Java backend against the existing Rails Postgres
# (docker-compose.java-shared.yaml). Copy to .env.java-shared and fill in real values.

# Use the SAME secret as your Rails .env so access tokens are interchangeable.
SECRET_KEY_BASE=replace_me_with_your_rails_secret

# Point at the shared Postgres container (service `postgres` on typerek_default).
# RAILS_ENV=development → the database is `typerek_development`.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me
POSTGRES_DB=typerek_development

PORT=8000

# Never seed into the real database; it already has schema + data.
APP_SEED=false

# Optional Discord link shown to signed-in users.
#TYPEREK_DISCORD_URL=https://discord.gg/your-invite
