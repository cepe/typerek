# Env for running the Java backend ALONGSIDE the main stack, on its Postgres
# (docker-compose.java-shared.yaml). This is the Java equivalent of the beta
# instance. Copy to .env.java-shared and fill in values from your prod/dev .env.

# Use the SAME secret as the Rails .env → JWT access tokens are interchangeable,
# so a user stays logged in whether the request hits Rails or Java.
SECRET_KEY_BASE=replace_me_with_your_rails_secret

# The shared Postgres container is reachable as `postgres` on typerek_default.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_me_with_your_postgres_password

# Which database to use:
#   typerek_production   -> the SAME data as the Rails production (RAILS_ENV=production)
#   typerek_development  -> your local dev database
POSTGRES_DB=typerek_production

PORT=8000

# Never seed an existing database — it already has schema + data.
APP_SEED=false

# Optional Discord link shown to signed-in users.
#TYPEREK_DISCORD_URL=https://discord.gg/your-invite
